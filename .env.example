# Azure OpenAI (LLM reasoning + email parsing). Leave AZURE_OPENAI_ENDPOINT
# blank for local dev — the LLM hooks fall back to their deterministic path.
# This is the Azure OpenAI *resource* endpoint (see infra/README.md), NOT the
# Foundry project endpoint. Provision it with infra/main.bicep.
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# gpt-5-series models require a 2025+ api-version (older ones 404/400).
AZURE_OPENAI_API_VERSION=2025-04-01-preview
MODEL_DEPLOYMENT_NAME=gpt-5-mini

# Azure AI Foundry project endpoint — reserved for future Foundry Agent Service
# tool-use (cross-shipment intelligence). Not used by the current LLM hooks.
AZURE_AI_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>

# Client ID of the user-assigned Managed Identity (set on the Container App).
# Binds DefaultAzureCredential (OpenAI) and the SQL ODBC driver
# (Authentication=ActiveDirectoryMsi) to the right identity. Blank locally.
AZURE_CLIENT_ID=

# Azure SQL (keyless, Managed Identity). Leave BOTH blank for local SQLite;
# set them and db.py builds an mssql+aioodbc / ActiveDirectoryMsi URL (needs the
# ODBC driver — present in the container image, not on the dev host).
AZURE_SQL_SERVER=      # e.g. sql-sc-xxxxx.database.windows.net
AZURE_SQL_DATABASE=    # e.g. scdb

# Azure AI Search (production — leave blank to skip email search)
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX_NAME=carrier-emails

# Azure Event Hubs (production — leave blank to use file-based GPS mock)
EVENTHUB_CONNECTION_STRING=
EVENTHUB_NAME=gps-tracking

# Agent thresholds
CONFIDENCE_THRESHOLD=0.85
COST_ESCALATION_THRESHOLD=50000
DAYS_OF_SUPPLY_CRITICAL=3

# Local development
DATABASE_URL=sqlite+aiosqlite:///./supply_chain.db
LOG_LEVEL=INFO
